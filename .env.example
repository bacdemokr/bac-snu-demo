# ---- bac-snu-demo .env.example ----
# Copy to .env (or export these before `node app/server.js`).
# NOTE: server.js does not auto-load .env; either export them or use a process
# manager. See INSTALL.md "Running" for the recommended launch command.

# --- OpenClaw gateway the bots talk to ---
# Default gateway URL when running on the same machine.
GATEWAY_URL=http://127.0.0.1:18789
# Gateway auth token. Found in your OpenClaw config at gateway.auth.token.
# Alternatively put it in app/.gw_token (preferred, see INSTALL.md).
GATEWAY_TOKEN=

# --- Web server ---
PORT=8080

# --- Workspace that holds node_modules/playwright-core and ./scripts ---
# Defaults to the repo root, which is correct for the standard layout.
# WORKSPACE=/absolute/path/to/bac-snu-demo

# --- GitHub demo target (GitHubAgent repo list + multi-agent PR) ---
# Must match the account whose PAT you give the OpenClaw "git" agent's GitHub MCP.
GH_OWNER=your-github-username
GH_REPO=NemoClaw

# --- Telegram two-way bridge bot (OPTIONAL) ---
# A SEPARATE bot from any OpenClaw Telegram integration. Create via @BotFather.
# Preferred: put the token in app/.tg_token instead of here.
TG_BOT_TOKEN=
# Optional: a chat id to send to before anyone messages the bot first.
TG_CHAT_ID=
